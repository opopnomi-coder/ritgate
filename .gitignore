# macOS
.DS_Store
**/.DS_Store

# Large build artifacts - never commit
*.apk
*.aab
*.ipa

# Backend - Local credentials (never commit)
backend/.env
backend/src/main/resources/application-local.properties

# Backend - Gradle build outputs
backend/build/
backend/.gradle/
backend/*.log

# Backend - Maven (not used but just in case)
backend/target/

# Frontend - Node modules & Expo
frontend/node_modules/
frontend/.expo/
frontend/dist/
frontend/.env
frontend/.env.local

# IDE
.vscode/
*.iml
.idea/

# Logs
*.log
